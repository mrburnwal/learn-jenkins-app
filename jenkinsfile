pipeline {
    agent none

    stages {
        stage('Build & Test') {
            agent {
                docker {
                    image 'node:18'
                    args '-u root:root' 
                }
            }
            steps {
                sh """
                   echo 'Installing dependencies and building...'
                   npm ci
                   npm run build
                   
                   echo 'Running unit tests...'
                   CI=true npm test
                """
            }
            // Fix: Move the junit report here, where the agent is active
            post {
                always {
                    junit 'test-results/junit.xml'
                }
            }
        }

        stage('E2E Tests') {
            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.39.0-jammy'
                    args '-u root:root'
                }
            }
            steps {
                sh """
                   echo 'Starting application and running E2E tests...'
                   npm install -g serve
                   serve -s build &
                   
                   # Wait for server to be ready (approx 10 seconds)
                   sleep 10
                   
                   npx playwright test
                """
            }
        }
    }
}
