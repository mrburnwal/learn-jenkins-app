pipeline {
    agent any

    stages {
        stage('Build & Test') {
            steps {
                script {
                    docker.image('node:18').inside("-e HOME=.cache") {
                        sh """
                           echo 'Installing dependencies and building...'
                           npm ci
                           npm run build
                           
                           echo 'Running unit tests...'
                           CI=true npm test
                        """
                    }
                }
            }
        }

        stage('E2E Tests') {
            steps {
                script {
                    docker.image('mcr.microsoft.com/playwright:v1.39.0-jammy').inside("-e HOME=.cache") {
                        sh """
                           echo 'Starting application and running E2E tests...'
                           npm install serve
                           ./node_modules/.bin/serve -s build &
                           sleep 10
                           npx playwright test
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            echo 'Recording test results and reports...'
            
            // Debug: Show where files are
            sh 'ls -R test-results || true'
            sh 'ls -R playwright-report || true'
            
            // Record any JUnit-style XML files found in the workspace
            junit '**/junit.xml'
            
            // Publish Playwright HTML Report
            publishHTML(target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'playwright-report',
                reportFiles: 'index.html',
                reportName: 'Playwright HTML Report'
            ])
        }
    }
}
