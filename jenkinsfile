pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                script {
                    docker.image('node:18').inside("-e HOME=.cache") {
                        sh """
                           echo 'Installing dependencies and building...'
                           npm ci
                           npm run build
                           
                           echo 'Running unit tests...'
                           CI=true npm test
                        """
                    }
                }
            }
            
        }

        stage('Unit Tests') {
            reuseWorkspace() {
                steps {
                    script {
                        docker.image('node:18').inside("-e HOME=.cache") {
                           echo 'Running unit tests...'
                           CI=true npm test
                        }
                    }
                }
            }
            post {
                always {
                    echo 'Recording Unit Test results...'
                    junit '**/junit.xml'
                }
            }
        }

        stage('E2E Tests') {
            steps {
                script {
                    docker.image('mcr.microsoft.com/playwright:v1.39.0-jammy').inside("-e HOME=.cache") {
                        sh """
                           echo 'Starting application and running E2E tests...'
                           npm install serve
                           ./node_modules/.bin/serve -s build &
                           sleep 10
                           npx playwright test
                        """
                    }
                }
            }
            post {
                always {
                    echo 'Publishing E2E HTML Report...'
                    publishHTML(target: [
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'playwright-report',
                        reportFiles: 'index.html',
                        reportName: 'Playwright HTML Report'
                    ])
                }
            }
        }
    }
}
