pipeline {
    agent none

    stages {
        stage('Build & Test') {
            agent {
                docker {
                    image 'node:18'
                    args '-e HOME=.cache'
                }
            }
            steps {
                sh """
                   echo 'Installing dependencies and building...'
                   npm ci
                   npm run build
                   
                   echo 'Running unit tests...'
                   CI=true npm test
                """
            }
            post {
                always {
                    junit 'test-results/junit.xml'
                }
            }
        }

        stage('E2E Tests') {
            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.39.0-jammy'
                    args '-e HOME=.cache'
                }
            }
            steps {
                sh """
                   echo 'Starting application and running E2E tests...'
                   npm install serve
                   node_modules/.bin/serve -s build &
                   sleep 10
                   npx playwright test
                """
            }
        }
    }
}
