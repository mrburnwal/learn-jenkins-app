pipeline{
    agent {
        docker {
            image 'node:18'
            reuseNode true
        }
    }

    stages{
        stage ('Build') {
            steps {
                sh """
                   echo 'Build NPM....!!!'
                   rm -rf node_modules
                   npm ci
                   npm run build
                """
            }
        }

        stage ('Test') {
            steps {
                sh """
                   echo "Running Tests....!!!"
                   npm test
                """
            }
        }

        stage ('Verify') {
            steps {
            sh """
                if [ -f test-results/junit.xml]; then
                    echo "Test results found"
                else
                    echo "Test result not found"
                fi
            """
            }
        }
    }
    post {
        always{
        junit 'test-results/junit.xml'
    }
}
}
