pipeline {
    agent any

    environment {
        NETLIFY_PROJECT_ID = "1bcc6f8d-5e6d-4ce7-8169-7ad1ab42433e"
        NETLIFY_AUTH_TOKEN = credentials('netlify_webapp_token')
    }

    stages {

        stage('Build') {
            agent {
                docker {
                    image 'node:18'
                    reuseNode true
                    args "-e HOME=.cache"
                }
            }
            steps {
                sh '''
                    ls -la
                    node --version
                    npm --version
                    npm ci
                    npm run build
                    ls -la
                '''
            }
        }

        stage('Tests') {
            parallel {
                stage('Unit tests') {
                    agent {
                        docker {
                            image 'node:18'
                            reuseNode true
                            args "-e HOME=.cache"
                        }
                    }

                    steps {
                        sh '''
                            test -f build/index.html
                            npm test
                        '''
                    }
                    post {
                        always {
                            junit 'test-results/junit.xml'
                        }
                    }
                }

                stage('E2E') {
                    agent {
                        docker {
                            image 'mcr.microsoft.com/playwright:v1.39.0-jammy'
                            reuseNode true
                            args "-e HOME=.cache"
                        }
                    }

                    steps {
                        sh '''
                            npm install serve
                            node_modules/.bin/serve -s build &
                            sleep 10
                            npx playwright test  --reporter=html
                        '''
                    }

                    post {
                        always {
                            publishHTML([allowMissing: false, alwaysLinkToLastBuild: false, keepAll: false, reportDir: 'playwright-report', reportFiles: 'index.html', reportName: 'Playwright HTML Report', reportTitles: '', useWrapperFileDirectly: true])
                        }
                    }
                }
            }
        }

        stage('Deploy Staging ') {
            agent {
                docker {
                    image 'node:18'
                    reuseNode true
                    args '-u root -e HOME=.cache'
                }
            }

            steps {
                sh '''
                    npm install netlify-cli node-jq
                    node_modules/.bin/netlify --version

                    echo "NETLIFY_PROJECT_ID: ${NETLIFY_PROJECT_ID}"
                    echo "NETLIFY_AUTH_TOKEN: ${NETLIFY_AUTH_TOKEN}"

                    node_modules/.bin/netlify link --id ${NETLIFY_PROJECT_ID}

                    node_modules/.bin/netlify status

                    echo "deploying to staging environment....!"

                    node_modules/.bin/netlify deploy --dir=build --json > staging-url.json
                    node_modules/.bin/node-jq '.deploy_url' staging-url.json
                '''
            }

            post {
                success {
                    script {
                        env.STAGING_URL = sh(script: 'node_modules/.bin/node-jq .deploy_url staging-url.json', returnStdout: true).trim()
                    }
                    echo "Staging URL: ${STAGING_URL}"
                }
            }
        }

        stage('Staging E2E Verify') {
            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.39.0-jammy'
                    reuseNode true
                    args "-e HOME=.cache"
                }
            }

            environment {
                CI_ENVIRONMENT_URL = "${env.STAGING_URL}"
            }

            steps {
                sh '''
                    npx playwright test  --reporter=html
                '''
            }

            post {
                always {
                    publishHTML([allowMissing: false, alwaysLinkToLastBuild: false, keepAll: false, reportDir: 'playwright-report', reportFiles: 'index.html', reportName: 'Playwright E2E Staging Report', reportTitles: '', useWrapperFileDirectly: true])
                }
            }
        }

        stage('Approval Stage') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    input message: 'Ready to Deploy?', ok: 'Yes, I want to continue.'
                }
            }
        }

        stage('Deploy Production') {
            agent {
                docker {
                    image 'node:18'
                    reuseNode true
                    args '-u root -e HOME=.cache'
                }
            }

            steps {
                sh '''
                    npm install netlify-cli
                    node_modules/.bin/netlify --version

                    echo "NETLIFY_PROJECT_ID: ${NETLIFY_PROJECT_ID}"
                    echo "NETLIFY_AUTH_TOKEN: ${NETLIFY_AUTH_TOKEN}"

                    node_modules/.bin/netlify link --id ${NETLIFY_PROJECT_ID}

                    node_modules/.bin/netlify status

                    echo "deploying to production environment....!"

                    node_modules/.bin/netlify deploy --dir=build --prod
                '''
            }
        }

        stage('Production E2E Verify') {
            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.39.0-jammy'
                    reuseNode true
                    args "-e HOME=.cache"
                }
            }

            environment {
                CI_ENVIRONMENT_URL = "https://grand-sprite-a334e6.netlify.app"
            }

            steps {
                sh '''
                    npx playwright test  --reporter=html
                '''
            }

            post {
                always {
                    publishHTML([allowMissing: false, alwaysLinkToLastBuild: false, keepAll: false, reportDir: 'playwright-report', reportFiles: 'index.html', reportName: 'Playwright E2E Post Report', reportTitles: '', useWrapperFileDirectly: true])
                }
            }
        }
    }
}
